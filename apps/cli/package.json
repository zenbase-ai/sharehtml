{
  "name": "sharehtml",
  "version": "0.0.3",
  "description": "Bun CLI for deploying local documents to sharehtml for collaborative commenting",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonesphillip/sharehtml.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/jonesphillip/sharehtml",
  "bugs": {
    "url": "https://github.com/jonesphillip/sharehtml/issues"
  },
  "bin": {
    "sharehtml": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "conf": "^13.0.0",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.0",
    "marked-highlight": "^2.2.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
